---
const posts = [
  {
    slug:     '/blog/machu-picchu',
    image:    '/images/Machupicchu/IMG_7709.webp',
    category: 'Destinos Imperdibles',
    date:     '10 de Octubre, 2025',
    readTime: '5 min',
    title:    'Machu Picchu: La Maravilla del Mundo Inca',
    excerpt:  'Todo lo que necesitas saber antes de visitar la ciudadela inca más famosa del planeta: entradas, rutas, mejores horas y consejos reales.',
    featured: true,
  },
  {
    slug:     '/blog/valle-sagrado',
    image:    '/images/Montaña_de_7_colores/DSC02961.webp',
    category: 'Experiencias',
    date:     '11 de Septiembre, 2025',
    readTime: '4 min',
    title:    'Descubre el Valle Sagrado: Ruinas y Espíritu Inca',
    excerpt:  'Ollantaytambo, Chinchero, ceremonias andinas y tejidos de colores imposibles. El Valle Sagrado es mucho más que ruinas.',
    featured: false,
  },
  {
    slug:     '/blog/vinicunca-7-colores',
    image:    '/images/ValleSagrado/moray.webp',
    category: 'Naturaleza & Aventura',
    date:     '11 de Abril, 2026',
    readTime: '4 min',
    title:    'Cerro de 7 Colores: la joya natural más sorprendente del Cusco',
    excerpt:  'A más de 5,000 metros sobre el nivel del mar, Vinicunca despliega una paleta de colores que parece pintada a mano por los Andes.',
    featured: false,
  },
];
---

<section class="blog-preview-section">

  <!-- Decoración de fondo -->
  <span class="bp-line-top"></span>
  <span class="bp-line-bottom"></span>
  <span class="bp-circle-tr"></span>
  <span class="bp-circle-bl"></span>

  <div class="container-pb bp-container">

    <!-- Header -->
    <div class="bp-header">
      <div class="bp-header-left">
        <span class="script-title" data-i18n="blog.badge">Perú Beyond</span>
        <h2 class="bp-title" data-i18n="blog.title">Blog de Viajes</h2>
        <p class="bp-subtitle" data-i18n="blog.subtitle">
          Historias reales, consejos prácticos y destinos que inspiran.
          Escrito por quienes conocen el Perú desde adentro.
        </p>
      </div>
      <a href="/blog" class="bp-cta-top">
        <span data-i18n="blog.see_all">Ver todos los artículos</span>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0-5 5m5-5H6"/>
        </svg>
      </a>
    </div>

    <!-- Cards -->
    <div class="bp-grid">
      {posts.map((post) => (
        <a href={post.slug} class={`bp-card ${post.featured ? 'bp-card--featured' : ''}`}>

          <!-- Imagen -->
          <div class="bp-img-wrap">
            <img src={post.image} alt={post.title} loading="lazy" />
            <span class="bp-category">{post.category}</span>
          </div>

          <!-- Contenido -->
          <div class="bp-body">
            <div class="bp-meta">
              <time>{post.date}</time>
              <span class="bp-dot">·</span>
              <span>{post.readTime} <span data-i18n="blog.read_time">de lectura</span></span>
            </div>
            <h3 class="bp-card-title">{post.title}</h3>
            <p class="bp-excerpt">{post.excerpt}</p>
            <span class="bp-read-more">
              <span data-i18n="blog.read_more">Leer artículo</span>
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0-5 5m5-5H6"/>
              </svg>
            </span>
          </div>

        </a>
      ))}
    </div>

    <!-- CTA inferior -->
    <div class="bp-cta-bottom">
      <a href="/blog" class="bp-btn-explore">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        <span data-i18n="blog.explore">Explorar más blogs</span>
      </a>
    </div>

  </div>
</section>

<style>
  /* ── Sección ── */
  .blog-preview-section {
    position: relative;
    overflow: hidden;
    padding: 6rem 0 5rem;

    /* Fondo blanco con patrón de diamante dorado */
    background-color: #ffffff;
    background-image:
      linear-gradient(45deg,  rgba(201,168,76,0.07) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(201,168,76,0.07) 25%, transparent 25%),
      linear-gradient(45deg,  transparent 75%, rgba(201,168,76,0.07) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(201,168,76,0.07) 75%);
    background-size: 20px 20px;
    background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
  }

  /* Fade del patrón hacia el centro */
  .blog-preview-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 50%, rgba(255,255,255,0.92) 0%, rgba(255,255,255,0.6) 55%, transparent 100%);
    pointer-events: none;
    z-index: 0;
  }

  /* Líneas doradas superior/inferior */
  .bp-line-top, .bp-line-bottom {
    position: absolute;
    left: 0; right: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, rgba(201,168,76,0.55) 30%, rgba(246,208,106,0.8) 50%, rgba(201,168,76,0.55) 70%, transparent);
    z-index: 1;
  }
  .bp-line-top    { top: 0; }
  .bp-line-bottom { bottom: 0; }

  /* Círculos decorativos */
  .bp-circle-tr {
    position: absolute;
    top: -100px; right: -100px;
    width: 380px; height: 380px;
    border-radius: 50%;
    border: 1px solid rgba(201,168,76,0.13);
    box-shadow: 0 0 0 36px rgba(201,168,76,0.045), 0 0 0 72px rgba(201,168,76,0.025);
    pointer-events: none; z-index: 0;
  }
  .bp-circle-bl {
    position: absolute;
    bottom: -80px; left: -80px;
    width: 300px; height: 300px;
    border-radius: 50%;
    border: 1px solid rgba(201,168,76,0.10);
    box-shadow: 0 0 0 30px rgba(201,168,76,0.035);
    pointer-events: none; z-index: 0;
  }

  /* Z-index wrapper */
  .bp-container { position: relative; z-index: 1; }

  /* ── Header ── */
  .bp-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  .bp-header-left { max-width: 520px; }
  .bp-title {
    font-family: 'Times New Roman', Times, serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #0D1B2E;
    line-height: 1.2;
    margin: 0.3rem 0 0.75rem;
  }
  .bp-title em {
    font-style: italic;
    color: #c9a84c;
  }
  .bp-subtitle {
    font-size: 0.9rem;
    color: #9ca3af;
    line-height: 1.75;
    max-width: 440px;
  }
  .bp-cta-top {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0D1B2E;
    text-decoration: none;
    border-bottom: 1.5px solid #c9a84c;
    padding-bottom: 2px;
    white-space: nowrap;
    transition: color 0.2s;
    flex-shrink: 0;
  }
  .bp-cta-top svg { width: 0.9rem; height: 0.9rem; transition: transform 0.2s; }
  .bp-cta-top:hover { color: #c9a84c; }
  .bp-cta-top:hover svg { transform: translateX(4px); }

  /* ── Grid ── */
  .bp-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  @media (max-width: 1024px) { .bp-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px)  { .bp-grid { grid-template-columns: 1fr; } }

  /* ── Card ── */
  .bp-card {
    background: #fff;
    border: 1px solid #ece7de;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
  }
  .bp-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(to right, #c9a84c, #f6d06a);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .bp-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.1);
  }
  .bp-card:hover::after { transform: scaleX(1); }

  /* ── Imagen ── */
  .bp-img-wrap {
    position: relative;
    overflow: hidden;
  }
  .bp-card--featured .bp-img-wrap { height: 320px; }
  .bp-card:not(.bp-card--featured) .bp-img-wrap { height: 200px; }

  .bp-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.65s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .bp-card:hover .bp-img-wrap img { transform: scale(1.06); }

  .bp-category {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    background: #0D1B2E;
    color: #f6d06a;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.7rem;
  }

  /* ── Body ── */
  .bp-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .bp-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    color: #c9a84c;
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-bottom: 0.65rem;
    text-transform: uppercase;
  }
  .bp-dot { color: #d1cdc6; }

  .bp-card-title {
    font-family: 'Times New Roman', Times, serif;
    font-size: 1rem;
    font-weight: 700;
    color: #0D1B2E;
    line-height: 1.45;
    margin-bottom: 0.65rem;
    transition: color 0.2s;
  }
  .bp-card--featured .bp-card-title { font-size: 1.2rem; }
  .bp-card:hover .bp-card-title { color: #c9a84c; }

  .bp-excerpt {
    font-size: 0.83rem;
    color: #9ca3af;
    line-height: 1.7;
    flex: 1;
    margin-bottom: 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bp-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0D1B2E;
    border-bottom: 1px solid #e8d9b0;
    padding-bottom: 1px;
    width: fit-content;
    transition: color 0.2s, border-color 0.2s, gap 0.2s;
  }
  .bp-read-more svg { width: 0.8rem; height: 0.8rem; }
  .bp-card:hover .bp-read-more {
    color: #c9a84c;
    border-color: #c9a84c;
    gap: 0.55rem;
  }

  /* ── CTA inferior ── */
  .bp-cta-bottom { text-align: center; }
  .bp-btn-explore {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #0D1B2E;
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 1rem 2.25rem;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.25s, transform 0.2s, box-shadow 0.25s;
    box-shadow: 0 4px 20px rgba(13,27,46,0.2);
  }
  .bp-btn-explore svg { width: 1.1rem; height: 1.1rem; }
  .bp-btn-explore:hover {
    background: #c9a84c;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(201,168,76,0.35);
  }
</style>
