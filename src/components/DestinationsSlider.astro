---
const destinos = [
  { name: 'Tours en Cusco', tours: 26, image: '/images/Cuzco/cusco.webp' },
  { name: 'Tours en Lima', tours: 10, image: '/images/Lima/lima.webp' },
  { name: 'Tours en Arequipa', tours: 7, image: '/images/Montaña_de_7_colores/DSC03311.webp' },
  { name: 'Tours en Ica', tours: 7, image: '/images/Huacachina/ica.jpg' },
  { name: 'Tours en Puno', tours: 2, image: '/images/Isla_de_los_uros/FT%201.webp' },
];
---
<section class="section destinations-section">
  <div class="container-pb">
    <div class="text-center mb-12">
      <span class="script-title" style="color: #f6d06a;" data-i18n="dest.badge">Destinos</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-2" style="color: #ffffff;" data-i18n="dest.title">Estos destinos te esperan… Más de lo que imaginas</h2>
      <p class="text-sm mt-3 max-w-xl mx-auto" style="color: rgba(255,255,255,0.55);" data-i18n="dest.desc">Explora los mejores destinos de Perú: Cusco, Lima, Arequipa y Puno. Cultura, historia y paisajes únicos te esperan en cada rincón. ¡Descúbrelos todos!</p>
    </div>
    <div class="swiper destinos-swiper">
      <div class="swiper-wrapper">
        {destinos.map(d => (
          <div class="swiper-slide">
            <a href="#" class="block relative overflow-hidden group" style="height: 420px; border-radius: 1rem;">
              <img src={d.image} alt={d.name} class="w-full h-full object-cover group-hover:scale-105 transition duration-700" />
              <div class="absolute bottom-0 left-0 right-0 text-white" style="background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.20) 50%, transparent 100%); padding: 4rem 1.5rem 1.5rem;">
                <h3 class="text-xl font-bold text-white mb-1">{d.name}</h3>
                <span class="text-sm font-bold text-white/80">{d.tours} Tours</span>
              </div>
            </a>
          </div>
        ))}
      </div>
      <div class="swiper-pagination !relative !mt-6"></div>
    </div>
  </div>
</section>
<style>
  .destinations-section {
    background:
      radial-gradient(ellipse at 20% 50%, rgba(201,168,76,0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.03) 0%, transparent 50%),
      linear-gradient(160deg, #0d1b2e 0%, #112438 55%, #0a1620 100%);
    position: relative;
    overflow: hidden;
  }
  .destinations-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c9a84c' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }
  .destinations-section .swiper-pagination-bullet {
    background: rgba(255,255,255,0.3) !important;
  }
  .destinations-section .swiper-pagination-bullet-active {
    background: #c9a84c !important;
  }
</style>
<script is:inline>
  window.addEventListener('load', () => {
    if (window.Swiper) new Swiper('.destinos-swiper', {
      slidesPerView: 1, spaceBetween: 20, pagination: { el: '.destinos-swiper .swiper-pagination', clickable: true },
      breakpoints: { 640: { slidesPerView: 2 }, 1024: { slidesPerView: 3 }, 1280: { slidesPerView: 5 } }
    });
  });
</script>
