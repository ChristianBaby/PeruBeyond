---
const destinos = [
  { name: 'Cusco', tours: 26, image: 'https://www.perubeyond.com/wp-content/uploads/2025/07/cusco-destino.webp' },
  { name: 'Lima', tours: 10, image: 'https://www.perubeyond.com/wp-content/uploads/2025/07/lima-destino.webp' },
  { name: 'Arequipa', tours: 7, image: 'https://www.perubeyond.com/wp-content/uploads/2025/07/arequipa-destino.webp' },
  { name: 'Ica', tours: 7, image: 'https://www.perubeyond.com/wp-content/uploads/2025/07/ica-destino.webp' },
];
---
<section class="section">
  <div class="container-pb">
    <div class="text-center mb-12">
      <span class="script-title">Destinos</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-2">Explora Nuestros Destinos</h2>
    </div>
    <div class="swiper destinos-swiper">
      <div class="swiper-wrapper">
        {destinos.map(d => (
          <div class="swiper-slide">
            <a href="#" class="block relative rounded-2xl overflow-hidden h-80 group">
              <img src={d.image} alt={d.name} class="w-full h-full object-cover group-hover:scale-110 transition duration-500" />
              <div class="absolute inset-0 bg-gradient-to-t from-navy/80 to-transparent"></div>
              <div class="absolute bottom-6 left-6 text-white">
                <h3 class="text-2xl font-bold text-white">{d.name}</h3>
                <span class="text-sm text-gold">{d.tours} Tours</span>
              </div>
            </a>
          </div>
        ))}
      </div>
      <div class="swiper-pagination !relative !mt-6"></div>
    </div>
  </div>
</section>
<script is:inline>
  window.addEventListener('load', () => {
    if (window.Swiper) new Swiper('.destinos-swiper', {
      slidesPerView: 1, spaceBetween: 20, pagination: { el: '.destinos-swiper .swiper-pagination', clickable: true },
      breakpoints: { 640: { slidesPerView: 2 }, 1024: { slidesPerView: 3 }, 1280: { slidesPerView: 4 } }
    });
  });
</script>
