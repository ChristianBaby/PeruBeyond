---
const payments = [
  { name: 'Visa',         img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/9/98/Visa_Inc._logo_%282005%E2%80%932014%29.svg/250px-Visa_Inc._logo_%282005%E2%80%932014%29.svg.png' },
  { name: 'PayPal',       img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/b/b5/PayPal.svg/250px-PayPal.svg.png' },
  { name: 'Amex',         img: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQ-U8tK4EfgFz0FAX0yYoXfE05yWfq2tqNLQw&s' },
  { name: 'Mastercard',   img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/2/2a/Mastercard-logo.svg/250px-Mastercard-logo.svg.png' },
  { name: 'Mercado pago', img: 'https://www.rojas.com.ar/wp-content/uploads/2024/10/version-horizontal-large-logo-mercado-pago.webp' },
];

const companyLinks = [
  { label: 'Operador de tours Perú', href: '#',       i18n: 'footer.link.operator' },
  { label: 'Sobre Nosotros',         href: '#about',  i18n: 'footer.link.about'    },
  { label: '¿Por qué PerúBeyond?',  href: '#',       i18n: 'footer.link.why'      },
  { label: 'Proyecto Social',        href: '#',       i18n: 'footer.link.social'   },
  { label: 'Blog de Viajes',         href: '#',       i18n: 'footer.link.blog'     },
  { label: 'Contáctanos',            href: '#',       i18n: 'footer.link.contact'  },
  { label: 'Términos y Condiciones', href: '#',       i18n: 'footer.link.terms'    },
  { label: 'Nuestras Licencias',     href: '#',       i18n: 'footer.link.licenses' },
];

const quickLinks = [
  { label: 'Tours en Cusco',          href: '#',           i18n: 'footer.link.cusco'    },
  { label: 'Tours a Machu Picchu',    href: '#machupicchu', i18n: 'footer.link.machu'    },
  { label: 'Camino Inca 2026',        href: '#',           i18n: 'footer.link.inca'     },
  { label: 'Tours de Trekking',       href: '#',           i18n: 'footer.link.trekking' },
  { label: 'Experiencia Cusco',       href: '#',           i18n: 'footer.link.exp'      },
  { label: 'Política de Privacidad',  href: '#',           i18n: 'footer.link.privacy'  },
];

const socials = [
  { icon: 'bi-facebook',  href: 'https://www.facebook.com/perubeyond' },
  { icon: 'bi-instagram', href: 'https://www.instagram.com/perubeyond/' },
  { icon: 'bi-tiktok',    href: 'https://www.tiktok.com/@perubeyond_agency' },
  { icon: 'bi-youtube',   href: '#' },
  { icon: 'bi-whatsapp',  href: 'https://wa.me/51943491959' },
];
---

<footer style="background-color:#0d1b2e;" class="text-white pt-14 pb-0">

  <!-- Top section -->
  <div class="container-pb grid md:grid-cols-4 gap-10 pb-12">

    <!-- Col 1: Logo -->
    <div class="flex flex-col gap-4">
      <img
        src="https://www.perubeyond.com/wp-content/uploads/2025/12/logo_pb.png"
        alt="Peru Beyond"
        class="max-w-[220px]"
      />
    </div>

    <!-- Col 2: About + Company Info -->
    <div>
      <h4 class="text-white font-bold text-sm uppercase mb-3 tracking-wide" data-i18n="footer.about_title">Sobre PerúBeyond</h4>
      <p class="text-sm text-gray-300 leading-relaxed mb-5" data-i18n="footer.about_desc">
        Operador de tours líder en Perú, brindando experiencias auténticas e inolvidables con atención personalizada y guías locales expertos.
      </p>
      <h4 class="text-white font-bold text-sm uppercase mb-3 tracking-wide" data-i18n="footer.info_title">Información de la Empresa</h4>
      <ul class="text-sm text-gray-300 space-y-1.5">
        <li><span class="font-bold text-white" data-i18n="footer.ruc">RUC</span>: 20608897926</li>
        <li><span class="font-bold text-white" data-i18n="footer.company_lbl">Empresa</span>: PERUBEYOND E.I.R.L</li>
        <li><span class="font-bold text-white" data-i18n="footer.address_lbl">Dirección</span>: Calle Zetas 109, Cusco 08002</li>
      </ul>
    </div>

    <!-- Col 3: Company links -->
    <div>
      <h4 class="text-white font-bold text-sm uppercase mb-4 tracking-wide" data-i18n="footer.our_company">Nuestra Empresa</h4>
      <ul class="space-y-2.5 text-sm text-gray-300">
        {companyLinks.map(link => (
          <li class="flex items-center gap-2">
            <span class="text-[#FFBC00] font-bold text-base leading-none">›</span>
            <a href={link.href} class="hover:text-white transition" data-i18n={link.i18n}>{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Col 4: Quick Links -->
    <div>
      <h4 class="text-white font-bold text-sm uppercase mb-4 tracking-wide" data-i18n="footer.quick_links">Enlaces Rápidos</h4>
      <ul class="space-y-2.5 text-sm text-gray-300">
        {quickLinks.map(link => (
          <li class="flex items-center gap-2">
            <span class="text-[#FFBC00] font-bold text-base leading-none">›</span>
            <a href={link.href} class="hover:text-white transition" data-i18n={link.i18n}>{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

  </div>

  <!-- Mid bar -->
  <div style="border-top:1px solid rgba(255,255,255,0.1);" class="container-pb py-8 grid grid-cols-2 md:grid-cols-4 gap-8 items-start">

    <div>
      <h4 class="text-white font-bold text-xs uppercase mb-4 tracking-wider" data-i18n="footer.book_holiday">Reserva tus Vacaciones</h4>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-[#FFBC00] flex items-center justify-center flex-shrink-0">
          <i class="bi bi-telephone-fill text-white"></i>
        </div>
        <a href="tel:+51943491959" class="text-sm text-gray-300 hover:text-white transition">+51 943 491 959</a>
      </div>
    </div>

    <div>
      <h4 class="text-white font-bold text-xs uppercase mb-4 tracking-wider" data-i18n="footer.email_us">Escríbenos</h4>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-[#FFBC00] flex items-center justify-center flex-shrink-0">
          <i class="bi bi-envelope-fill text-white"></i>
        </div>
        <div class="flex flex-col gap-1">
          <a href="mailto:info@perubeyond.com" class="text-xs text-gray-300 hover:text-white transition">info@perubeyond.com</a>
          <a href="mailto:reservas@perubeyond.com" class="text-xs text-gray-300 hover:text-white transition">reservas@perubeyond.com</a>
        </div>
      </div>
    </div>

    <div>
      <h4 class="text-white font-bold text-xs uppercase mb-4 tracking-wider" data-i18n="footer.follow_us">Síguenos</h4>
      <div class="flex items-center gap-2 flex-wrap">
        {socials.map(s => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-[#FFBC00] hover:bg-[#e6a900] transition flex items-center justify-center"
          >
            <i class={`bi ${s.icon} text-white`}></i>
          </a>
        ))}
      </div>
    </div>

    <div>
      <h4 class="text-white font-bold text-xs uppercase mb-4 tracking-wider" data-i18n="footer.payment">Métodos de Pago</h4>
      <div class="flex flex-wrap gap-2">
        {payments.map(p => (
          <div class="pay-card" title={p.name}>
            <img src={p.img} alt={p.name} class="h-4 w-auto object-contain" />
          </div>
        ))}
      </div>
    </div>

  </div>

  <style>
    .pay-card {
      background-color: #ffffff;
      border-radius: 6px;
      height: 34px;
      width: 58px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 8px;
      flex-shrink: 0;
    }
  </style>

  <!-- Copyright -->
  <div style="border-top:1px solid rgba(255,255,255,0.08);" class="py-4 text-center text-xs text-gray-400">
    <span data-i18n="footer.copyright">Copyright © 2026 Todos los derechos reservados | 🔒 Desarrollado por PerúBeyond</span>
  </div>

</footer>
