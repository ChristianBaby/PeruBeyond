  <div class="px-8 py-6 border-t border-white/10 space-y-3">
    <p class="text-gold font-bold uppercase text-[10px] tracking-widest" data-i18n="cta.contact_us">Contáctanos</p>
    <a href="tel:+51943491959" class="flex items-center gap-2 text-white font-bold text-lg">
      <i class="bi bi-telephone-fill text-gold text-sm"></i> +51 943 491 959
    </a>
    <a href="https://wa.me/51943491959" target="_blank"
       class="flex items-center gap-2 bg-green-500 text-white font-bold px-5 py-3 rounded-xl text-sm justify-center">
      <i class="bi bi-whatsapp"></i>
      <span data-i18n="cta.whatsapp">WhatsApp directo</span>
    </a>
  </div>
</div>

<script is:inline>
  const header     = document.getElementById('main-header');
  const links      = document.querySelectorAll('.header-link');
  const phone      = document.querySelector('.header-phone');
  const burger     = document.querySelector('.header-burger');
  const mobileMenu = document.getElementById('mobile-menu');
  const openBtn    = document.getElementById('mobile-menu-btn');
  const closeBtn   = document.getElementById('close-menu-btn');

  function onScroll() {
    const scrolled = window.scrollY > 60;
    header.classList.toggle('bg-white',       scrolled);
    header.classList.toggle('shadow-md',      scrolled);
    header.classList.toggle('bg-transparent', !scrolled);
    links.forEach(l => {
      l.classList.toggle('text-white', !scrolled);
      l.classList.toggle('text-navy',   scrolled);
    });
    if (phone)  { phone.classList.toggle('text-white',  !scrolled); phone.classList.toggle('text-navy',  scrolled); }
    if (burger) { burger.classList.toggle('text-white', !scrolled); burger.classList.toggle('text-navy', scrolled); }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  openBtn?.addEventListener('click', () => mobileMenu?.classList.remove('translate-x-full'));
  closeBtn?.addEventListener('click', () => mobileMenu?.classList.add('translate-x-full'));

  document.querySelectorAll('.mobile-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item    = btn.closest('.mobile-item');
      const submenu = item?.querySelector('.mobile-submenu');
      const icon    = btn.querySelector('i');
      const isOpen  = submenu?.style.maxHeight && submenu.style.maxHeight !== '0px';

      document.querySelectorAll('.mobile-submenu').forEach(s => s.style.maxHeight = '0px');
      document.querySelectorAll('.mobile-trigger i').forEach(i => i.style.transform = '');

      if (!isOpen && submenu) {
        submenu.style.maxHeight = submenu.scrollHeight + 'px';
        if (icon) icon.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
