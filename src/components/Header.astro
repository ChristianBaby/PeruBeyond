    <button id="close-menu-btn" class="text-white text-3xl p-1">
      <i class="bi bi-x"></i>
    </button>
  </div>

  <nav class="flex-1 px-6 py-6 space-y-1">
    {menu.map((m, i) => (
      <div class="mobile-item border-b border-white/10">
        <button
          class="mobile-trigger w-full flex items-center justify-between py-4 text-white text-base font-black uppercase tracking-tight hover:text-gold transition-colors"
          data-index={String(i)}>
          <span data-i18n={m.navKey}>{m.label}</span>
          <i class="bi bi-chevron-down text-xs text-white/40 transition-transform duration-300"></i>
        </button>
        <div class="mobile-submenu overflow-hidden max-h-0 transition-all duration-400">
          <div class="pb-4 pl-2 space-y-2">
            {m.type === 'mega-peru' && m.details.links.map(l => (
              <a href={l.h || "#"} class="block text-white/60 hover:text-gold text-sm py-1.5 transition-colors">{l.n}</a>
            ))}
            {m.type === 'mega-machu' && m.details.tours.map(t => (
              <a href={t.href} class="flex items-center justify-between text-white/60 hover:text-gold text-sm py-1.5 transition-colors">
                {t.name} <span class="text-xs text-white/30">{t.duration}</span>
              </a>
            ))}
            {m.type === 'mega-cusco' && m.details.categories.map(cat => (
              <div class="mb-3">
                <p class="text-gold text-[10px] uppercase tracking-widest font-bold mb-1">{cat.title}</p>
                {cat.tours.map(t => (
                  <a href={t.href} class="block text-white/60 hover:text-gold text-sm py-1 pl-2 transition-colors">{t.name}</a>
                ))}
              </div>
            ))}
            {m.type === 'mega-brand' && m.details.links.map(l => (
              <a href={l.h} class="flex items-center gap-2 text-white/60 hover:text-gold text-sm py-1.5 transition-colors">
                <i class={`bi ${l.icon} text-xs`}></i>
                <span data-i18n={l.i18n}>{l.n}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    ))}
