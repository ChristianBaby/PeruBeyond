---
export interface Props {
  image: string;
  title: string;
  duration: string;
  price: string;
  oldPrice?: string;
  location?: string;
  description: string;
  href?: string;
}
const { image, title, duration, price, oldPrice, location, description, href = '#' } = Astro.props;
---

<a href={href} class="tour-card group">

  <!-- Barra dorada superior -->
  <div class="card-top-bar"></div>

  <!-- Imagen -->
  <div class="card-img-wrap">
    <img src={image} alt={title} loading="lazy" />
    <div class="card-img-overlay">
      <span class="card-duration-badge">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        {duration}
      </span>
    </div>
  </div>

  <!-- Contenido -->
  <div class="card-body">

    <!-- Ubicación -->
    {location && (
      <div class="card-location">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        {location}
      </div>
    )}

    <!-- Título -->
    <h3 class="card-title">{title}</h3>

    <!-- Separador -->
    <div class="card-sep"></div>

    <!-- Descripción -->
    <p class="card-desc">{description}</p>

    <!-- Precio + CTA -->
    <div class="card-footer">
      <div class="card-price">
        <span class="price-label" data-i18n="card.from">Desde</span>
        <div class="price-row">
          <span class="price-amount">${price}</span>
          <span class="price-currency">USD</span>
          {oldPrice && <span class="price-old">${oldPrice}</span>}
        </div>
      </div>
      <span class="card-btn">
        <span data-i18n="card.quote">Cotizar</span>
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0-5 5m5-5H6"/>
        </svg>
      </span>
    </div>

  </div>

  <!-- Línea inferior animada -->
  <div class="card-bottom-line"></div>

</a>

<style>
  .tour-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid #ece7de;
    border-top: none;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .tour-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
  }

  /* Barra dorada superior */
  .card-top-bar {
    height: 3px;
    background: linear-gradient(to right, #c9a84c, #f6d06a, #c9a84c);
    flex-shrink: 0;
  }

  /* Imagen */
  .card-img-wrap {
    position: relative;
    overflow: hidden;
    height: 230px;
    flex-shrink: 0;
  }
  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.65s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .tour-card:hover .card-img-wrap img { transform: scale(1.06); }

  .card-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%);
    display: flex;
    align-items: flex-end;
    padding: 0.75rem;
  }
  .card-duration-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(13,27,46,0.85);
    color: #f6d06a;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    backdrop-filter: blur(4px);
  }
  .card-duration-badge svg { width: 0.75rem; height: 0.75rem; }

  /* Cuerpo */
  .card-body {
    padding: 1.25rem 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-location {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #c9a84c;
    margin-bottom: 0.5rem;
  }
  .card-location svg { width: 0.7rem; height: 0.7rem; }

  .card-title {
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: #0D1B2E;
    line-height: 1.45;
    margin-bottom: 0.75rem;
    transition: color 0.2s;
  }
  .tour-card:hover .card-title { color: #c9a84c; }

  /* Separador dorado */
  .card-sep {
    width: 2rem;
    height: 1.5px;
    background: linear-gradient(to right, #c9a84c, #f6d06a);
    margin-bottom: 0.75rem;
    transition: width 0.3s ease;
  }
  .tour-card:hover .card-sep { width: 3.5rem; }

  .card-desc {
    font-size: 0.78rem;
    color: #9ca3af;
    line-height: 1.7;
    flex: 1;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Footer precio + botón */
  .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding-top: 0.85rem;
    border-top: 1px solid #f3ede3;
  }

  .card-price { line-height: 1; }
  .price-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9ca3af;
    display: block;
    margin-bottom: 0.3rem;
  }
  .price-row {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }
  .price-amount {
    font-family: 'Times New Roman', Times, serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: #c9a84c;
    line-height: 1;
  }
  .price-currency {
    font-size: 0.62rem;
    font-weight: 700;
    color: #9ca3af;
    letter-spacing: 0.06em;
  }
  .price-old {
    font-size: 0.72rem;
    color: #d1cdc6;
    text-decoration: line-through;
  }

  /* Botón flat */
  .card-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: #0D1B2E;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.55rem 1rem;
    transition: background 0.25s, gap 0.2s;
    flex-shrink: 0;
  }
  .card-btn svg { width: 0.75rem; height: 0.75rem; }
  .tour-card:hover .card-btn {
    background: #c9a84c;
    gap: 0.55rem;
  }

  /* Línea inferior animada */
  .card-bottom-line {
    height: 2px;
    background: linear-gradient(to right, #c9a84c, #f6d06a);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
    flex-shrink: 0;
  }
  .tour-card:hover .card-bottom-line { transform: scaleX(1); }
</style>
