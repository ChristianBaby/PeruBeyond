---
const features = [
  { key: 'why.f1', icon: 'bi-compass',      num: '01', title: 'Guías Locales Certificados',  desc: 'Nacidos en estas tierras, conocen cada sendero, historia y secreto que los libros nunca cuentan.' },
  { key: 'why.f2', icon: 'bi-person-check',  num: '02', title: 'Experiencias Personalizadas', desc: 'Cada itinerario nace de una conversación contigo: tus tiempos, tus pasiones, tu forma de viajar.' },
  { key: 'why.f3', icon: 'bi-leaf',          num: '03', title: 'Turismo Responsable',         desc: 'Preservamos la cultura local, apoyamos comunidades y cuidamos cada ecosistema que visitamos.' },
  { key: 'why.f4', icon: 'bi-headset',       num: '04', title: 'Soporte en Español 24/7',     desc: 'Un equipo real disponible por WhatsApp desde tu primera consulta hasta tu regreso a casa.' },
  { key: 'why.f5', icon: 'bi-people',        num: '05', title: 'Grupos Reducidos',            desc: 'Máxima atención, mínima masificación. Cada experiencia es íntima, auténtica y completamente tuya.' },
  { key: 'why.f6', icon: 'bi-shield-check',  num: '06', title: 'Seguridad y Confianza',       desc: 'Operamos con licencias oficiales y respaldados por las principales instituciones turísticas del Perú.' },
];
---

<section id="por-que-nosotros" class="why-section">

  <!-- ── Header ── -->
  <div class="why-header">
    <div class="container-pb">
      <div class="header-inner">
        <div class="header-text">
          <span class="script-title" style="color:#c9a84c;" data-i18n="why.badge">PerúBeyond</span>
          <h2 class="why-title" data-i18n="why.title">¿Por qué elegirnos como tu operador turístico en Perú?</h2>
          <p class="why-subtitle" data-i18n="why.subtitle">
            Más de una década creando viajes únicos con la calidez, el conocimiento
            y la pasión de quienes nacieron amando estas tierras.
          </p>
        </div>
        <div class="header-badge">
          <span class="badge-num">+1200</span>
          <span class="badge-label" data-i18n="why.badge_label">Viajeros felices</span>
          <div class="badge-stars">
            {[...Array(5)].map(() => <i class="bi bi-star-fill"></i>)}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Feature cards ── -->
  <div class="features-bg">
    <div class="container-pb">
      <div class="features-grid">
        {features.map(f => (
          <div class="feat-card">
            <div class="feat-top">
              <div class="feat-icon-wrap">
                <i class={`bi ${f.icon} feat-icon`}></i>
              </div>
              <span class="feat-num">{f.num}</span>
            </div>
            <h3 class="feat-title" data-i18n={`${f.key}.title`}>{f.title}</h3>
            <p class="feat-desc" data-i18n={`${f.key}.desc`}>{f.desc}</p>
            <div class="feat-line"></div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="cta-row">
        <a href="https://wa.me/51943491959" target="_blank" rel="noopener" class="cta-btn">
          <i class="bi bi-whatsapp"></i>
          <span data-i18n="why.cta">Planifica tu Aventura</span>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

</section>

<style>
  .why-section { overflow: hidden; }

  .why-header {
    background: #f8f6f3;
    padding: 5rem 0 4rem;
    border-bottom: 1px solid #ece7de;
  }
  .header-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .header-text { max-width: 640px; }
  .why-title {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 800;
    color: #0d1b2e;
    line-height: 1.25;
    margin: 0.4rem 0 1rem;
  }
  .why-subtitle {
    font-size: 0.95rem;
    color: #9ca3af;
    line-height: 1.75;
    max-width: 500px;
  }

  .header-badge {
    background: #0d1b2e;
    padding: 1.5rem 2rem;
    text-align: center;
    min-width: 160px;
    flex-shrink: 0;
  }
  .badge-num {
    display: block;
    font-family: Georgia, serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: #f6d06a;
    line-height: 1;
    margin-bottom: 0.35rem;
  }
  .badge-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin-bottom: 0.75rem;
  }
  .badge-stars { display: flex; justify-content: center; gap: 0.2rem; }
  .badge-stars i { color: #f6d06a; font-size: 0.65rem; }

  .features-bg {
    background:
      radial-gradient(ellipse at 5% 40%, rgba(201,168,76,0.07) 0%, transparent 55%),
      radial-gradient(ellipse at 95% 60%, rgba(201,168,76,0.05) 0%, transparent 50%),
      linear-gradient(160deg, #0d1b2e 0%, #112238 60%, #0a1620 100%);
    padding: 5rem 0 4rem;
    position: relative;
  }
  .features-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23c9a84c' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }
  .features-bg .container-pb { position: relative; z-index: 1; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 3.5rem;
  }
  @media (max-width: 1024px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .features-grid { grid-template-columns: 1fr; } }

  .feat-card {
    background: rgba(255,255,255,0.03);
    padding: 2.25rem 2rem;
    position: relative;
    transition: background 0.3s;
    overflow: hidden;
  }
  .feat-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(to right, #c9a84c, #f6d06a);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .feat-card:hover { background: rgba(201,168,76,0.06); }
  .feat-card:hover::after { transform: scaleX(1); }

  .feat-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  .feat-icon-wrap {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 8px;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s, border-color 0.3s;
  }
  .feat-card:hover .feat-icon-wrap {
    background: rgba(201,168,76,0.2);
    border-color: rgba(201,168,76,0.5);
  }
  .feat-icon { font-size: 1.15rem; color: #c9a84c; }
  .feat-num {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.2);
    transition: color 0.3s;
  }
  .feat-card:hover .feat-num { color: rgba(201,168,76,0.5); }

  .feat-title {
    font-family: Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.6rem;
    line-height: 1.4;
    transition: color 0.3s;
  }
  .feat-card:hover .feat-title { color: #f6d06a; }

  .feat-desc {
    font-size: 0.84rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    margin: 0;
  }
  .feat-line { display: none; }

  .cta-row { text-align: center; }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #c9a84c;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 1rem 2.25rem;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.25s, transform 0.2s, box-shadow 0.25s;
    box-shadow: 0 4px 20px rgba(201,168,76,0.3);
  }
  .cta-btn i { font-size: 1rem; }
  .cta-btn:hover {
    background: #a07830;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(201,168,76,0.4);
  }
</style>
