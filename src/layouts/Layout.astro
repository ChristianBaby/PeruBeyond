---
import '../styles/global.css';
import { ui } from '../i18n/ui';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  langAlternates?: { es?: string; en?: string; pt?: string };
}

const {
  title = 'Peru Beyond - Más de lo que Imaginas',
  description = 'Agencia de viajes en Cusco. Tours a Machu Picchu, Valle Sagrado y todo Perú.',
  ogImage = 'https://www.perubeyond.com/wp-content/uploads/2025/12/logo_pb.png',
  langAlternates,
} = Astro.props;

const siteBase = Astro.site ?? new URL('https://www.perubeyond.com');
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const ogImageAbs = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteBase).href;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Peru Beyond" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <!-- hreflang para tours multilingüe -->
    {langAlternates?.es && <link rel="alternate" hreflang="es" href={langAlternates.es} />}
    {langAlternates?.en && <link rel="alternate" hreflang="en" href={langAlternates.en} />}
    {langAlternates?.pt && <link rel="alternate" hreflang="pt-BR" href={langAlternates.pt} />}
    {langAlternates && <link rel="alternate" hreflang="x-default" href={langAlternates.es ?? canonicalURL.href} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Satisfy&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <slot name="head" />
    <!-- i18n: embed translations & apply on load -->
    <script define:vars={{ i18nData: ui }} is:inline>
      window.__pb_i18n = i18nData;

      window.__pb_applyLang = function (lang) {
        var t = window.__pb_i18n[lang] || window.__pb_i18n['es'];
        document.querySelectorAll('[data-i18n]').forEach(function (el) {
          var key = el.getAttribute('data-i18n');
          if (t[key] !== undefined) el.textContent = t[key];
        });
        document.documentElement.lang = lang === 'pt' ? 'pt-BR' : lang;
        var flagEl = document.getElementById('lang-flag');
        var codeEl = document.getElementById('lang-code');
        var map = { es: { flag: '🇵🇪', code: 'ES' }, en: { flag: '🇺🇸', code: 'EN' }, pt: { flag: '🇧🇷', code: 'PT' } };
        if (flagEl && map[lang]) flagEl.textContent = map[lang].flag;
        if (codeEl && map[lang]) codeEl.textContent = map[lang].code;
        // Rewrite tour detail links to include the correct language prefix.
        // Only rewrite if the path has at least 2 segments after /tours/
        // (e.g. /tours/cusco/some-tour), skipping category pages (/tours/cusco).
        document.querySelectorAll('a[href^="/tours/"]').forEach(function (a) {
          var href = a.getAttribute('href');
          if (!href) return;
          var clean = href.replace(/^\/tours\/(en|pt)\//, '/tours/');
          var afterTours = clean.replace(/^\/tours\//, '').replace(/\/$/, '');
          if (!afterTours || afterTours.indexOf('/') === -1) return;
          a.setAttribute('href', lang === 'es' ? clean : clean.replace('/tours/', '/tours/' + lang + '/'));
        });
      };

      document.addEventListener('DOMContentLoaded', function () {
        // If we're on a tour page the language is encoded in the URL — sync it to localStorage
        var pathMatch = window.location.pathname.match(/^\/tours\/(en|pt)\//);
        var urlLang = pathMatch ? pathMatch[1] : null;
        if (urlLang) localStorage.setItem('pb_lang', urlLang);
        var urlParams = new URLSearchParams(window.location.search);
        var lang = urlLang || urlParams.get('lang') || localStorage.getItem('pb_lang') || 'es';
        window.__pb_applyLang(lang);
      });
    </script>
  </head>
  <body class="bg-white">
    <slot />
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" is:inline></script>
  </body>
</html>
