      'Apoya el turismo local: contrata guías y compra snacks a los pobladores.',
      'Evita el plástico: lleva botella reutilizable y no dejes basura.',
    ],
    conclusion: 'Visitar el Cerro de 7 Colores es mucho más que ver un paisaje espectacular: es sentir la energía de los Andes y entender por qué el Perú sigue siendo uno de los destinos más mágicos del mundo. Prepárate, respira profundo y deja que la montaña te hable.',
  },
  };
  return Object.entries(blogsData).map(([slug, blog]) => ({
    params: { slug },
    props: { blog },
  }));
}

const { blog } = Astro.props;
const { slug } = Astro.params;
---

<Layout title={`${blog.title} | Perú Beyond`} description={blog.sections[0].paragraphs[0]}>
  <Header />

  <main>
    <!-- ── Hero ── -->
    <section class="blog-hero" style={`background-image: url('${blog.heroImage}'); background-position: ${blog.heroPosition};`}>
      <div class="hero-overlay">
        <div class="hero-inner">
          <nav class="breadcrumb">
            <a href="/">Inicio</a>
            <span>›</span>
            <a href="/blog">Blog</a>
            <span>›</span>
            <span class="current">{blog.title}</span>
          </nav>
          <span class="category-badge">{blog.category}</span>
          <h1 class="hero-title">{blog.title}</h1>
          <div class="hero-meta">
            <span>
              <svg class="meta-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              {blog.date}
            </span>
            <span class="meta-dot">·</span>
            <span>
              <svg class="meta-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              {blog.readTime}
            </span>
            <span class="meta-dot">·</span>
            <span>
              <svg class="meta-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              {blog.views} Vistas
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Article ── -->
    <div class="article-wrapper">
      <article class="article-card">

        <!-- Author row -->
        <div class="author-row">
          <div class="author-avatar">{blog.author.charAt(0)}</div>
          <div>
            <p class="author-label">Por,</p>
            <p class="author-name">{blog.author}</p>
          </div>
          <div class="author-divider"></div>
          <div class="share-row">
            <span class="share-label">Compartir:</span>
            <a href={`https://wa.me/?text=${encodeURIComponent(blog.title)}`} class="share-btn" aria-label="WhatsApp" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.852L0 24l6.335-1.518A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.797 9.797 0 01-4.988-1.365l-.357-.212-3.758.9.946-3.658-.232-.376A9.818 9.818 0 012.182 12C2.182 6.575 6.575 2.182 12 2.182S21.818 6.575 21.818 12 17.425 21.818 12 21.818z"/></svg>
            </a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent('https://perubeyond.com/blog/' + slug)}`} class="share-btn" aria-label="Facebook" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </div>
        </div>

        <div class="gold-separator"></div>

        <!-- Content sections -->
        {blog.sections.map((section) => (
          <div class={section.heading ? 'content-section' : 'intro-section'}>
            {section.heading && <h2 class="section-heading">{section.heading}</h2>}
            {section.paragraphs.map((p) => (
              <p class={section.heading ? 'body-text' : 'intro-text'}>{p}</p>
            ))}
            {section.highlight && (
              <blockquote class="pull-quote">
                <p>{section.highlight}</p>
              </blockquote>
            )}
            {section.image && (
              <figure class="article-figure">
                <img src={section.image} alt={section.imageCaption ?? ''} loading="lazy" />
                {section.imageCaption && <figcaption>{section.imageCaption}</figcaption>}
              </figure>
            )}
          </div>
        ))}

        <!-- Tips box -->
        <div class="tips-box">
          <div class="tips-header">
            <svg class="tips-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            <h3>Tips para tu visita</h3>
          </div>
          <ul class="tips-list">
            {blog.tips.map((tip) => (
              <li>
                <svg class="tip-check" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Conclusion -->
        <div class="conclusion-section">
          <div class="conclusion-line"></div>
          <p class="conclusion-text">{blog.conclusion}</p>
        </div>

        <!-- Back link -->
        <div class="back-row">
          <a href="/blog" class="back-link">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
            Volver al Blog
          </a>
        </div>

      </article>
    </div>

    <!-- ── CTA ── -->
    <section class="cta-section">
      <div class="cta-inner">
        <p class="cta-tag">¿Listo para la aventura?</p>
        <h2 class="cta-title">Vive esta experiencia con <span>Perú Beyond</span></h2>
        <p class="cta-desc">Nuestro equipo de expertos locales diseña viajes únicos, seguros y auténticos. Contáctanos y planifica tu próxima aventura peruana.</p>
        <div class="cta-buttons">
          <a href="https://wa.me/51943491959" class="btn-primary" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.852L0 24l6.335-1.518A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.797 9.797 0 01-4.988-1.365l-.357-.212-3.758.9.946-3.658-.232-.376A9.818 9.818 0 012.182 12C2.182 6.575 6.575 2.182 12 2.182S21.818 6.575 21.818 12 17.425 21.818 12 21.818z"/></svg>
            Reservar por WhatsApp
          </a>
          <a href="/blog" class="btn-secondary">Ver más artículos</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .blog-hero {
    position: relative;
    height: 70vh;
    min-height: 480px;
    background-size: cover;
    background-attachment: fixed;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.25) 0%,
      rgba(0,0,0,0.55) 60%,
      rgba(0,0,0,0.78) 100%
    );
    display: flex;
    align-items: flex-end;
    padding-bottom: 3.5rem;
  }
  .hero-inner {
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover { color: #f6d06a; }
  .breadcrumb .current {
    color: rgba(255,255,255,0.75);
    max-width: 300px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .category-badge {
    display: inline-block;
    background: #c9a84c;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.28rem 0.85rem;
    border-radius: 2px;
    margin-bottom: 0.9rem;
  }
  .hero-title {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.7rem, 4.5vw, 3rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.25;
    margin-bottom: 1.1rem;
    text-shadow: 0 2px 20px rgba(0,0,0,0.45);
    max-width: 780px;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.65);
  }
  .hero-meta span {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .meta-icon {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
  }
  .meta-dot { color: rgba(255,255,255,0.3); }

  /* ── Article wrapper ── */
  .article-wrapper {
    background: #f8f6f3;
    padding: 0 1rem 5rem;
  }
  .article-card {
    max-width: 800px;
    margin: 0 auto;
    background: #fff;
    border-radius: 4px 4px 0 0;
    box-shadow: 0 4px 40px rgba(0,0,0,0.08);
    padding: 2.5rem 2.5rem 3rem;
    position: relative;
    top: -3rem;
  }
  @media (max-width: 640px) {
    .article-card { padding: 1.75rem 1.25rem 2rem; }
  }

  /* ── Author row ── */
  .author-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .author-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, #c9a84c, #f6d06a);
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .author-label { font-size: 0.7rem; color: #9ca3af; margin: 0; line-height: 1.2; }
  .author-name  { font-size: 0.85rem; font-weight: 700; color: #1a1208; margin: 0; }
  .author-divider {
    flex: 1;
    height: 1px;
    background: #ece7de;
    min-width: 1rem;
  }
  .share-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .share-label { font-size: 0.68rem; color: #9ca3af; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; }
  .share-btn {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    background: #f3ede3;
    color: #c9a84c;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s;
  }
  .share-btn svg { width: 0.85rem; height: 0.85rem; }
  .share-btn:hover { background: #c9a84c; color: #fff; }

  /* ── Gold separator ── */
  .gold-separator {
    height: 2px;
    background: linear-gradient(to right, #c9a84c, #f6d06a, transparent);
    margin-bottom: 2rem;
    border-radius: 1px;
  }

  /* ── Intro ── */
  .intro-section { margin-bottom: 2rem; }
  .intro-text {
    font-family: Georgia, serif;
    font-size: 1.125rem;
    line-height: 1.85;
    color: #2d2d2d;
    margin-bottom: 1.1rem;
  }

  /* ── Sections ── */
  .content-section { margin-bottom: 2.25rem; }
  .section-heading {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #0d1b2e;
    margin-bottom: 1rem;
    padding-left: 1rem;
    border-left: 3px solid #c9a84c;
    line-height: 1.4;
  }
  .body-text {
    font-size: 0.97rem;
    line-height: 1.85;
    color: #4b4b4b;
    margin-bottom: 0.9rem;
  }

  /* ── Pull quote ── */
  .pull-quote {
    border-left: 4px solid #c9a84c;
    margin: 1.75rem 0;
    padding: 1rem 1.5rem;
    background: #faf7f0;
    border-radius: 0 4px 4px 0;
  }
  .pull-quote p {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 1.05rem;
    color: #5a4a2a;
    line-height: 1.7;
    margin: 0;
  }

  /* ── Article figure ── */
  .article-figure {
    margin: 2rem 0;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  .article-figure img {
    width: 100%;
    height: 340px;
    object-fit: cover;
    display: block;
  }
  .article-figure figcaption {
    padding: 0.6rem 1rem;
    font-size: 0.78rem;
    color: #9ca3af;
    font-style: italic;
    background: #faf7f0;
    border-top: 1px solid #ece7de;
    text-align: center;
  }

  /* ── Tips box ── */
  .tips-box {
    background: #fdf9f0;
    border: 1px solid #e8d9b0;
    border-left: 4px solid #c9a84c;
    border-radius: 4px;
    padding: 1.5rem 1.75rem;
    margin: 2.5rem 0;
  }
  .tips-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }
  .tips-icon {
    width: 1.2rem;
    height: 1.2rem;
    color: #c9a84c;
    flex-shrink: 0;
  }
  .tips-header h3 {
    font-family: Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    color: #5a4a2a;
    margin: 0;
  }
  .tips-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .tips-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: #4b4b4b;
    line-height: 1.55;
  }
  .tip-check {
    width: 1rem;
    height: 1rem;
    color: #c9a84c;
