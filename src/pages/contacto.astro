---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contacto | Peru Beyond"
  description="Contáctanos para reservar tu tour ideal en Perú. Teléfono, WhatsApp, email y oficina en Cusco."
>
  <Header />

  <!-- Hero -->
  <section style="background:linear-gradient(135deg,#0d1b2e 0%,#1a3050 60%,#0d1b2e 100%); padding-top:140px; padding-bottom:70px;" class="relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image:url('https://www.perubeyond.com/wp-content/uploads/2025/12/logo_pb.png'); background-repeat:no-repeat; background-position:right center; background-size:400px;"></div>
    <div class="container-pb relative z-10 text-center">
      <p class="script-title text-2xl mb-3">Estamos aquí para ti</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Contáctanos</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        ¿Listo para vivir el Perú auténtico? Escríbenos, llámanos o visítanos en nuestra oficina en Cusco. Con gusto te ayudamos a planear tu aventura perfecta.
      </p>
    </div>
  </section>

  <!-- Tarjetas de contacto rápido -->
  <section class="section" style="background:#f7f8fa;">
    <div class="container-pb">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <!-- Teléfono -->
        <a href="tel:+51943491959" class="group bg-white rounded-2xl shadow-md hover:shadow-xl transition-all p-6 flex flex-col items-center text-center gap-3 border-b-4 border-transparent hover:border-[#FFBC00]">
          <div class="w-14 h-14 rounded-full bg-[#FFBC00] flex items-center justify-center group-hover:scale-110 transition-transform">
            <i class="bi bi-telephone-fill text-white text-xl"></i>
          </div>
          <h3 class="font-bold text-[#0d1b2e] text-base">Teléfono</h3>
          <p class="text-gray-500 text-sm">+51 943 491 959</p>
          <span class="text-xs text-[#FFBC00] font-semibold">Llamar ahora →</span>
        </a>

        <!-- WhatsApp -->
        <a href="https://wa.me/51943491959" target="_blank" rel="noopener" class="group bg-white rounded-2xl shadow-md hover:shadow-xl transition-all p-6 flex flex-col items-center text-center gap-3 border-b-4 border-transparent hover:border-[#25D366]">
          <div class="w-14 h-14 rounded-full bg-[#25D366] flex items-center justify-center group-hover:scale-110 transition-transform">
            <i class="bi bi-whatsapp text-white text-xl"></i>
          </div>
          <h3 class="font-bold text-[#0d1b2e] text-base">WhatsApp</h3>
          <p class="text-gray-500 text-sm">+51 943 491 959</p>
          <span class="text-xs text-[#25D366] font-semibold">Escribir ahora →</span>
        </a>

        <!-- Email -->
        <a href="mailto:info@perubeyond.com" class="group bg-white rounded-2xl shadow-md hover:shadow-xl transition-all p-6 flex flex-col items-center text-center gap-3 border-b-4 border-transparent hover:border-[#FFBC00]">
          <div class="w-14 h-14 rounded-full bg-[#FFBC00] flex items-center justify-center group-hover:scale-110 transition-transform">
            <i class="bi bi-envelope-fill text-white text-xl"></i>
          </div>
          <h3 class="font-bold text-[#0d1b2e] text-base">Email</h3>
          <p class="text-gray-500 text-sm">info@perubeyond.com</p>
          <p class="text-gray-500 text-xs">reservas@perubeyond.com</p>
          <span class="text-xs text-[#FFBC00] font-semibold">Enviar email →</span>
        </a>

        <!-- Ubicación -->
        <a href="https://maps.google.com/?q=Calle+Zetas+109,+Cusco,+Peru" target="_blank" rel="noopener" class="group bg-white rounded-2xl shadow-md hover:shadow-xl transition-all p-6 flex flex-col items-center text-center gap-3 border-b-4 border-transparent hover:border-[#FFBC00]">
          <div class="w-14 h-14 rounded-full bg-[#FFBC00] flex items-center justify-center group-hover:scale-110 transition-transform">
            <i class="bi bi-geo-alt-fill text-white text-xl"></i>
          </div>
          <h3 class="font-bold text-[#0d1b2e] text-base">Oficina</h3>
          <p class="text-gray-500 text-sm">Calle Zetas 109</p>
          <p class="text-gray-500 text-sm">Cusco 08002, Perú</p>
          <span class="text-xs text-[#FFBC00] font-semibold">Ver en mapa →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- Formulario + Mapa -->
  <section class="section bg-white">
    <div class="container-pb">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Formulario de contacto -->
        <div>
          <p class="script-title text-xl mb-2">Cuéntanos tu aventura</p>
          <h2 class="text-3xl font-bold text-[#0d1b2e] mb-6">Envíanos un mensaje</h2>

          <form class="flex flex-col gap-4" action="https://formspree.io/f/info@perubeyond.com" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-semibold text-[#0d1b2e] mb-1">Nombre *</label>
                <input type="text" name="nombre" required placeholder="Tu nombre"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#FFBC00] transition" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-[#0d1b2e] mb-1">Apellido</label>
                <input type="text" name="apellido" placeholder="Tu apellido"
                  class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#FFBC00] transition" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-[#0d1b2e] mb-1">Email *</label>
              <input type="email" name="email" required placeholder="tu@email.com"
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#FFBC00] transition" />
            </div>

            <div>
              <label class="block text-sm font-semibold text-[#0d1b2e] mb-1">Teléfono / WhatsApp</label>
              <input type="tel" name="telefono" placeholder="+51 ..."
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#FFBC00] transition" />
            </div>

            <div>
              <label class="block text-sm font-semibold text-[#0d1b2e] mb-1">Tour de interés</label>
              <select name="tour" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#FFBC00] transition text-gray-500">
                <option value="">Selecciona un destino</option>
                <option>Machu Picchu</option>
                <option>Valle Sagrado</option>
                <option>Camino Inca</option>
                <option>Tours en Cusco</option>
                <option>Tours Perú completo</option>
                <option>Otro</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-semibold text-[#0d1b2e] mb-1">Mensaje *</label>
              <textarea name="mensaje" required rows="4" placeholder="Cuéntanos cuándo viajas, cuántas personas son y qué experiencia buscas..."
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#FFBC00] transition resize-none"></textarea>
            </div>

            <button type="submit" class="btn-gold text-center w-full py-4 text-base font-bold tracking-wide rounded-xl">
              <i class="bi bi-send-fill mr-2"></i>Enviar mensaje
            </button>
          </form>
        </div>

        <!-- Mapa + Horarios -->
        <div class="flex flex-col gap-6">

          <!-- Google Maps embed -->
          <div class="rounded-2xl overflow-hidden shadow-md" style="height:320px;">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3751.5!2d-71.9734!3d-13.5243!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x916e7f6f8e0b0001%3A0x0!2sCalle+Zetas+109%2C+Cusco%2C+Peru!5e0!3m2!1ses!2spe!4v1700000000000"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Oficina Peru Beyond Cusco"
            ></iframe>
          </div>

          <!-- Horarios -->
          <div class="bg-[#f7f8fa] rounded-2xl p-6">
            <h3 class="font-bold text-[#0d1b2e] text-base mb-4 flex items-center gap-2">
              <i class="bi bi-clock-fill text-[#FFBC00]"></i> Horarios de atención
            </h3>
            <ul class="space-y-2 text-sm text-gray-600">
              <li class="flex justify-between border-b border-gray-200 pb-2">
                <span class="font-semibold text-[#0d1b2e]">Lunes – Viernes</span>
                <span>8:00 am – 6:00 pm</span>
              </li>
              <li class="flex justify-between border-b border-gray-200 pb-2">
                <span class="font-semibold text-[#0d1b2e]">Sábado</span>
                <span>9:00 am – 4:00 pm</span>
              </li>
              <li class="flex justify-between">
                <span class="font-semibold text-[#0d1b2e]">Domingo</span>
                <span>Cerrado</span>
              </li>
            </ul>
            <p class="text-xs text-gray-400 mt-4">
              <i class="bi bi-whatsapp text-[#25D366]"></i> WhatsApp disponible todos los días hasta las 9:00 pm.
            </p>
          </div>

          <!-- Info empresa -->
          <div class="bg-[#0d1b2e] rounded-2xl p-6 text-white">
            <h3 class="font-bold text-sm uppercase tracking-wide text-[#FFBC00] mb-3">Información de la Empresa</h3>
            <ul class="space-y-2 text-sm text-gray-300">
              <li><span class="font-bold text-white">Empresa:</span> PERUBEYOND E.I.R.L</li>
              <li><span class="font-bold text-white">RUC:</span> 20608897926</li>
              <li><span class="font-bold text-white">Dirección:</span> Calle Zetas 109, Cusco 08002</li>
              <li><span class="font-bold text-white">Teléfono:</span> +51 943 491 959</li>
              <li><span class="font-bold text-white">Email:</span> info@perubeyond.com</li>
            </ul>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Redes Sociales -->
  <section class="section" style="background:linear-gradient(135deg,#0d1b2e 0%,#1a3050 100%);">
    <div class="container-pb text-center">
      <p class="script-title text-xl mb-2">Síguenos</p>
      <h2 class="text-3xl font-bold text-white mb-4">Conéctate con nosotros</h2>
      <p class="text-gray-300 mb-10 max-w-xl mx-auto">
        Sigue nuestras redes para inspirarte con destinos increíbles, tips de viaje y las mejores ofertas.
      </p>
      <div class="flex flex-wrap justify-center gap-5">

        <a href="https://www.facebook.com/perubeyond" target="_blank" rel="noopener"
          class="group flex flex-col items-center gap-2 transition">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-white text-2xl group-hover:scale-110 transition-transform shadow-lg" style="background:#1877F2;">
            <i class="bi bi-facebook"></i>
          </div>
          <span class="text-gray-300 text-xs font-semibold">Facebook</span>
        </a>

        <a href="https://www.instagram.com/perubeyond/" target="_blank" rel="noopener"
          class="group flex flex-col items-center gap-2 transition">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-white text-2xl group-hover:scale-110 transition-transform shadow-lg" style="background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);">
            <i class="bi bi-instagram"></i>
          </div>
          <span class="text-gray-300 text-xs font-semibold">Instagram</span>
        </a>

        <a href="https://www.tiktok.com/@perubeyond_agency" target="_blank" rel="noopener"
          class="group flex flex-col items-center gap-2 transition">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-white text-2xl group-hover:scale-110 transition-transform shadow-lg" style="background:#010101;">
            <i class="bi bi-tiktok"></i>
          </div>
          <span class="text-gray-300 text-xs font-semibold">TikTok</span>
        </a>

        <a href="https://wa.me/51943491959" target="_blank" rel="noopener"
          class="group flex flex-col items-center gap-2 transition">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-white text-2xl group-hover:scale-110 transition-transform shadow-lg" style="background:#25D366;">
            <i class="bi bi-whatsapp"></i>
          </div>
          <span class="text-gray-300 text-xs font-semibold">WhatsApp</span>
        </a>

        <a href="#" target="_blank" rel="noopener"
          class="group flex flex-col items-center gap-2 transition">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-white text-2xl group-hover:scale-110 transition-transform shadow-lg" style="background:#FF0000;">
            <i class="bi bi-youtube"></i>
          </div>
          <span class="text-gray-300 text-xs font-semibold">YouTube</span>
        </a>

      </div>
    </div>
  </section>

  <Footer />
</Layout>
