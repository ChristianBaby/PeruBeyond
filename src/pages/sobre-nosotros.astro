---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const certLogos = [
  { src: 'https://gercetur.com.pe/wp-content/uploads/2025/11/LOGO-POSITIVO-scaled-e1763582114614.png',           alt: 'Gercetur'    },
  { src: 'https://www.perubeyond.com/wp-content/uploads/2026/01/marca-peru-peru-beyond-2_1_-748x1024.webp',      alt: 'Marca Perú'  },
  { src: 'https://www.perubeyond.com/wp-content/uploads/2026/01/tripadvisor-peru-beyond_1_.webp',                alt: 'TripAdvisor' },
  { src: 'https://www.perubeyond.com/wp-content/uploads/2026/01/protegeme-peru-beyond_1_.webp',                  alt: 'Protegeme'   },
  { src: 'https://www.wayraqperu.com/wp-content/uploads/mincetur.png',                                           alt: 'Mincetur'    },
];

const reasons = [
  { title: 'Guías Locales Certificados',       desc: 'Nacidos en estas tierras, nuestros guías conocen cada sendero, historia y secreto que los libros no cuentan.' },
  { title: 'Experiencias 100% Personalizadas', desc: 'Cada itinerario nace de una conversación contigo: tus tiempos, tus pasiones y tu forma única de viajar.' },
  { title: 'Turismo Responsable',              desc: 'Viajamos con conciencia. Preservamos la cultura local, apoyamos comunidades y cuidamos cada ecosistema.' },
  { title: 'Soporte en Español 24/7',          desc: 'Un equipo real siempre disponible por WhatsApp, desde tu primera consulta hasta tu regreso a casa.' },
  { title: 'Grupos Reducidos',                 desc: 'Máxima atención, mínima masificación. Cada experiencia es íntima, auténtica y completamente tuya.' },
  { title: 'Reserva Flexible',                 desc: 'Adaptamos los tours a tus necesidades y cambios de último minuto sin complicaciones.' },
];
---

<Layout>
  <Header />

  <!-- ══ PORTADA / COVER HERO ══ -->
  <section class="cover-hero">
    <img
      src="/images/Machupicchu/IMG_7715.webp"
      alt="Sobre Nosotros — Peru Beyond"
      class="cover-img"
    />
    <div class="cover-overlay"></div>

    <div class="cover-content">
      <p class="cover-eyebrow">Peru Beyond</p>
      <h1 class="cover-title">
        Sobre <span class="cover-title-gold">Nosotros</span>
      </h1>
      <div class="cover-divider">
        <div class="divider-line"></div>
        <div class="divider-dot"></div>
        <div class="divider-line divider-line--rev"></div>
      </div>
      <nav class="cover-breadcrumb">
        <a href="/">Inicio</a>
        <i class="bi bi-chevron-right"></i>
        <span>Sobre Nosotros</span>
      </nav>
    </div>

    <div class="cover-scroll">
      <span>Descubrir</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ══ CUERPO: fondo blanco ══ -->
  <div class="page-body">
    <div class="page-container">

      <!-- ── SECCIÓN 1: Quiénes somos ── -->
      <section class="section-who">
        <div class="who-text">
          <span class="script-title">Nuestra Historia</span>
          <h2 class="section-heading">
            Más que una agencia,<br/>somos tu compañero<br/>de aventura.
          </h2>
          <div class="gold-rule"></div>
          <p class="body-text">
            Somos una agencia peruana dedicada a ofrecer tours auténticos, seguros y diseñados a
            medida. Creemos que viajar va mucho más allá de visitar lugares: se trata de sentir,
            conectar y llevarte algo que cambie tu forma de ver el mundo.
          </p>
          <p class="body-text body-text--mb">
            Cada experiencia que creamos nace del profundo amor de nuestro equipo por el Perú —
            su cultura, sus paisajes, su historia y la calidez inigualable de su gente.
          </p>
          <div class="cta-row">
            <a href="/" class="btn-dark">
              Descubre Más
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0-5 5m5-5H6"/>
              </svg>
            </a>
            <a href="https://wa.me/51943491959" target="_blank" rel="noopener noreferrer" class="btn-wa">
              <span class="wa-icon"><i class="bi bi-whatsapp"></i></span>
              Escríbenos
            </a>
          </div>
        </div>

        <div class="who-media">
          <div class="media-frame"></div>
          <img
            src="/images/Laguna_Humantay/DSC04385.webp"
            alt="Equipo Peru Beyond"
            class="media-img"
          />
          <div class="media-badge">
            <div class="badge-rule"></div>
            <span class="badge-label">Nuestra Esencia</span>
            <p class="badge-text">Turismo auténtico desde el corazón del Perú.</p>
          </div>
        </div>
      </section>

      <!-- ── SECCIÓN 2: Filosofía ── -->
      <section class="section-philosophy">
        <div class="philosophy-inner">
          <div class="philosophy-bg-glow"></div>
          <div class="philosophy-content">
            <div class="phi-header">
              <div class="phi-line"></div>
              <span class="script-title phi-eyebrow">Nuestra Filosofía</span>
              <div class="phi-line phi-line--rev"></div>
            </div>
            <p class="phi-quote">
              "Viajamos con alma,<br/>
              <span class="phi-quote-gold">guiamos con pasión."</span>
            </p>
            <p class="phi-body">
              Cada destino que visitamos es un capítulo de una historia más grande — la tuya. Nuestro
              propósito es que regreses a casa diferente, con recuerdos que duren toda la vida.
            </p>
            <div class="phi-footer">
              <div class="phi-line-sm"></div>
              <div class="phi-dot"></div>
              <div class="phi-line-sm phi-line-sm--rev"></div>
            </div>
          </div>
        </div>
      </section>

      <!-- ── SECCIÓN 3: Por qué elegirnos ── -->
      <section class="section-reasons">
        <div class="reasons-header">
          <span class="script-title">Por Qué Nosotros</span>
          <h2 class="section-heading">Lo que nos hace distintos</h2>
          <div class="gold-rule gold-rule--center"></div>
        </div>

        <ul class="reasons-list">
          {reasons.map((r, i) => (
            <li class="reason-row">
              <span class="reason-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="reason-body">
                <h3 class="reason-title">{r.title}</h3>
                <p class="reason-desc">{r.desc}</p>
              </div>
              <svg class="reason-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0-5 5m5-5H6"/>
              </svg>
            </li>
          ))}
        </ul>
      </section>

      <!-- ── SECCIÓN 4: Certificaciones ── -->
      <section class="section-certs">
        <div class="certs-header">
          <span class="script-title">Avales y Certificaciones</span>
          <h3 class="certs-title">Respaldados por las mejores instituciones</h3>
          <p class="certs-sub">
            Operamos bajo los más altos estándares de calidad y seguridad reconocidos a nivel nacional.
          </p>
        </div>
        <div class="certs-logos">
          {certLogos.map(logo => (
            <img
              src={logo.src}
              alt={logo.alt}
              class="cert-logo"
            />
          ))}
        </div>
      </section>

    </div>
  </div>

  <Footer />
</Layout>

<style>
  /* ════════════════════════════════
     PORTADA / COVER HERO
  ════════════════════════════════ */
  .cover-hero {
    position: relative;
    height: 78vh;
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    transform: scale(1.04);
    transition: transform 8s ease-out;
  }
  .cover-hero:hover .cover-img { transform: scale(1); }

  .cover-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 8, 5, 0.30) 0%,
      rgba(10, 8, 5, 0.55) 50%,
      rgba(10, 8, 5, 0.75) 100%
    );
  }

  .cover-content {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 0 1rem;
  }
  .cover-eyebrow {
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.75rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.8);
    margin-bottom: 1.25rem;
  }
  .cover-title {
    font-family: 'Times New Roman', Times, serif;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    color: #fff;
    line-height: 1;
    margin-bottom: 1.5rem;
    text-shadow: 0 4px 32px rgba(0,0,0,0.4);
    letter-spacing: -0.02em;
  }
  .cover-title-gold { color: #c9a84c; }

  /* Divider dorado */
  .cover-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .divider-line {
    width: 64px;
    height: 1px;
    background: linear-gradient(to right, transparent, #c9a84c);
  }
  .divider-line--rev { background: linear-gradient(to left, transparent, #c9a84c); }
  .divider-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #c9a84c;
  }

  .cover-breadcrumb {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
  }
  .cover-breadcrumb a { color: inherit; transition: color 0.2s; }
  .cover-breadcrumb a:hover { color: #fff; }
  .cover-breadcrumb i { font-size: 0.6rem; }
  .cover-breadcrumb span { color: rgba(255,255,255,0.85); }

  /* Scroll indicator */
  .cover-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255,255,255,0.4);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(201,168,76,0.6), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50%       { opacity: 1;   transform: scaleY(1.1); }
  }

  /* ════════════════════════════════
     CUERPO BLANCO
  ════════════════════════════════ */
  .page-body { background: #fff; }
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  /* Helpers */
  .section-heading {
    font-family: 'Times New Roman', Times, serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: #0D1B2E;
    line-height: 1.2;
    margin: 0.75rem 0 1.5rem;
  }
  .gold-rule {
    width: 40px;
    height: 2px;
    background: #c9a84c;
    margin-bottom: 1.5rem;
  }
  .gold-rule--center { margin: 1.25rem auto 0; }
  .body-text { color: #9ca3af; line-height: 1.8; margin-bottom: 1rem; font-size: 0.97rem; }
  .body-text--mb { margin-bottom: 2.5rem; }

  /* ── Quiénes somos ── */
  .section-who {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 768px) { .section-who { grid-template-columns: 1fr; gap: 2.5rem; } }

  .cta-row { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .btn-dark {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #111827;
    color: #fff;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    padding: 0.875rem 1.75rem;
    border-radius: 9999px;
    transition: background 0.3s, transform 0.2s;
  }
  .btn-dark svg { width: 1rem; height: 1rem; }
  .btn-dark:hover { background: #c9a84c; transform: translateY(-1px); }

  .btn-wa {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #6b7280;
    transition: color 0.25s;
  }
  .btn-wa:hover { color: #c9a84c; }
  .wa-icon {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    border: 1.5px solid #fde68a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: #c9a84c;
    transition: border-color 0.25s;
  }
  .btn-wa:hover .wa-icon { border-color: #c9a84c; }

  /* Imagen con marco */
  .who-media { position: relative; }
  .media-frame {
    position: absolute;
    top: -10px;
    right: -10px;
    width: 100%;
    height: 100%;
    border-radius: 1rem;
    border: 1.5px solid rgba(201,168,76,0.25);
    pointer-events: none;
  }
  .media-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 440px;
    object-fit: cover;
    border-radius: 1rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.10);
  }
  .media-badge {
    position: absolute;
    z-index: 2;
    bottom: -1.5rem;
    left: -1.5rem;
    background: #fff;
    border: 1px solid #f3ede1;
    border-radius: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.09);
    padding: 1.25rem 1.5rem;
    max-width: 200px;
  }
  .badge-rule { width: 1.5rem; height: 2px; background: #c9a84c; margin-bottom: 0.6rem; }
  .badge-label {
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.75rem;
    color: #c9a84c;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.3rem;
  }
  .badge-text { font-size: 0.82rem; font-weight: 600; color: #374151; line-height: 1.4; }

  /* ── Filosofía ── */
  .section-philosophy { border-radius: 1.5rem; overflow: hidden; }
  .philosophy-inner {
    background: linear-gradient(135deg, #1a1208 0%, #231807 50%, #1a1208 100%);
    padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 6vw, 5rem);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .philosophy-bg-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse at 50% 50%, rgba(201,168,76,0.07) 0%, transparent 68%);
  }
  .philosophy-content { position: relative; }

  .phi-header { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 2rem; }
  .phi-line { width: 56px; height: 1px; background: linear-gradient(to right, transparent, #c9a84c); }
  .phi-line--rev { background: linear-gradient(to left, transparent, #c9a84c); }
  .phi-eyebrow { color: #c9a84c !important; font-size: 1rem; }

  .phi-quote {
    font-family: 'Times New Roman', Times, serif;
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    max-width: 700px;
    margin: 0 auto 1.5rem;
  }
  .phi-quote-gold { color: #c9a84c; }

  .phi-body {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.5);
    max-width: 520px;
    margin: 0 auto 2rem;
    line-height: 1.8;
  }

  .phi-footer { display: flex; align-items: center; justify-content: center; gap: 0.75rem; }
  .phi-line-sm { width: 40px; height: 1px; background: linear-gradient(to right, transparent, rgba(201,168,76,0.35)); }
  .phi-line-sm--rev { background: linear-gradient(to left, transparent, rgba(201,168,76,0.35)); }
  .phi-dot { width: 5px; height: 5px; border-radius: 50%; background: rgba(201,168,76,0.5); }

  /* ── Por qué elegirnos ── */
  .section-reasons {
    background: #faf9f7;
    border-radius: 1.5rem;
    padding: clamp(2.5rem, 5vw, 4rem);
  }
  .reasons-header { text-align: center; max-width: 480px; margin: 0 auto 3.5rem; }

  .reasons-list { list-style: none; padding: 0; margin: 0; border-top: 1px solid #ece7de; }
  .reason-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid #ece7de;
    cursor: default;
    transition: background 0.2s;
  }
  .reason-num {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    color: #c9a84c;
    opacity: 0.5;
    min-width: 1.8rem;
    transition: opacity 0.25s;
  }
  .reason-row:hover .reason-num { opacity: 1; }

  .reason-body { flex: 1; min-width: 0; }
  .reason-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0D1B2E;
    margin-bottom: 0.25rem;
    transition: color 0.25s;
    font-family: 'Times New Roman', Times, serif;
  }
  .reason-row:hover .reason-title { color: #c9a84c; }
  .reason-desc { font-size: 0.82rem; color: #9ca3af; line-height: 1.6; }

  .reason-arrow {
    width: 1.1rem;
    height: 1.1rem;
    color: #d1d5db;
    flex-shrink: 0;
    transition: color 0.25s, transform 0.25s;
  }
  .reason-row:hover .reason-arrow { color: #c9a84c; transform: translateX(4px); }

  /* ── Certificaciones ── */
  .section-certs { text-align: center; }
  .certs-header { margin-bottom: 3rem; }
  .certs-title {
    font-family: 'Times New Roman', Times, serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #0D1B2E;
    margin: 0.5rem 0 0.75rem;
  }
  .certs-sub { font-size: 0.88rem; color: #9ca3af; max-width: 380px; margin: 0 auto; line-height: 1.7; }

  .certs-logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid #f0ebe2;
  }
  .cert-logo {
    height: 3.5rem;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.45;
    transition: filter 0.35s, opacity 0.35s, transform 0.25s;
  }
  .cert-logo:hover { filter: grayscale(0); opacity: 1; transform: scale(1.06); }
</style>
