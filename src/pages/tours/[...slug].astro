  <!-- FUNCION PARA LA FUNCION DEL CARRUCEL DE LOS ITINERARIOS  -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const state: Record<string, number> = {};
  
      function getTrack(id: string): HTMLElement | null {
        return document.querySelector(`.carousel-track[data-carousel="${id}"]`);
      }
  
      function getSlides(id: string): HTMLElement[] {
        const track = getTrack(id);
        return track ? Array.from(track.querySelectorAll('.carousel-slide')) : [];
      }
  
      function updateCarousel(id: string) {
        const slides = getSlides(id);
        if (!slides.length) return;
        const current = state[id] ?? 0;
        const slideWidth = slides[0].getBoundingClientRect().width + 12;
        const track = getTrack(id);
        if (track) track.style.transform = `translateX(-${current * slideWidth}px)`;
  
        document.querySelectorAll(`[data-dots="${id}"] .dot`).forEach((dot, i) => {
          const el = dot as HTMLElement;
          el.classList.toggle('bg-orange-500', i === current);
          el.classList.toggle('!w-4', i === current);
          el.classList.toggle('bg-gray-300', i !== current);
        });
      }
  
      document.querySelectorAll('.carousel-next').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.target!;
          const max = Math.max(0, getSlides(id).length - 3);
          state[id] = Math.min((state[id] ?? 0) + 1, max);
          updateCarousel(id);
        });
      });
  
      document.querySelectorAll('.carousel-prev').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.target!;
          state[id] = Math.max((state[id] ?? 0) - 1, 0);
          updateCarousel(id);
        });
      });
  
      document.querySelectorAll('[data-dots] .dot').forEach(dot => {
        dot.addEventListener('click', () => {
          const id = (dot as HTMLElement).dataset.carousel!;
          state[id] = parseInt((dot as HTMLElement).dataset.index!);
          updateCarousel(id);
        });
      });
    });
  </script>




  <!-- SECCION PARA EL FUNCIONAMIENTO DE LA GALERIA DE IMAGENES  -->
  <script define:vars={{ galleryImages: gallery ?? [], videoUrl: videoUrl ?? '' }}>
    let currentIndex = 0;
  
    function openLightbox(index) {
      currentIndex = index;
      const lb = document.getElementById('lightbox');
      const img = document.getElementById('lightbox-img');
      const counter = document.getElementById('lightbox-counter');
      if (!lb || !img) return;
      img.src = galleryImages[currentIndex];
      img.alt = `Foto ${currentIndex + 1}`;
      if (counter) counter.textContent = `${currentIndex + 1} / ${galleryImages.length}`;
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
  
    function closeLightbox() {
      const lb = document.getElementById('lightbox');
      if (!lb) return;
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
    }
  
    document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
    document.getElementById('lightbox')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeLightbox();
    });
  
    // Botón Siguiente
    document.getElementById('lightbox-next')?.addEventListener('click', () => {
      currentIndex = (currentIndex + 1) % galleryImages.length;
      const img = document.getElementById('lightbox-img');
      const counter = document.getElementById('lightbox-counter');
      
      if (img instanceof HTMLImageElement) {
        img.src = galleryImages[currentIndex];
      }
      
      if (counter) {
        counter.textContent = `${currentIndex + 1} / ${galleryImages.length}`;
      }
    });
  
    // Botón Anterior
    document.getElementById('lightbox-prev')?.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + galleryImages.length) % galleryImages.length;
      const img = document.getElementById('lightbox-img');
      const counter = document.getElementById('lightbox-counter');
      
      if (img instanceof HTMLImageElement) {
        img.src = galleryImages[currentIndex];
      }
      
      if (counter) {
        counter.textContent = `${currentIndex + 1} / ${galleryImages.length}`;
      }
    });
  
    // Teclado
    document.addEventListener('keydown', (e) => {
      const lb = document.getElementById('lightbox');
      if (!lb || lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') document.getElementById('lightbox-next')?.click();
      if (e.key === 'ArrowLeft') document.getElementById('lightbox-prev')?.click();
    });
  
    // Botón de video
    document.getElementById('gallery-video-btn')?.addEventListener('click', () => {
      if (!videoUrl) return;
      const videoId = videoUrl.includes('v=') ? videoUrl.split('v=')[1].split('&')[0] : videoUrl.split('/').pop();
      window.open(`https://www.youtube.com/watch?v=${videoId}`, '_blank');
    });
  </script>


  <!--  Funcionamiento de las Preguntas Frecuentes  -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.faq-trigger').forEach(trigger => {
        trigger.addEventListener('click', () => {
          const index = (trigger as HTMLElement).dataset.index!;
          const item = document.querySelector(`.faq-item[data-index="${index}"]`);
          if (!item) return;

          const answer = item.querySelector('.faq-answer') as HTMLElement;
          const icon = item.querySelector('.faq-icon') as HTMLElement;
          const isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';

          // Cerrar todos
          document.querySelectorAll('.faq-item').forEach(el => {
            const a = el.querySelector('.faq-answer') as HTMLElement;
            const ic = el.querySelector('.faq-icon') as HTMLElement;
            if (a) a.style.maxHeight = '0px';
            if (ic) { ic.textContent = '+'; ic.classList.remove('bg-gold', 'text-white', 'border-gold'); }
          });

          // Abrir el clickeado si estaba cerrado
          if (!isOpen) {
            answer.style.maxHeight = answer.scrollHeight + 'px';
            icon.textContent = '−';
            icon.classList.add('bg-gold', 'text-white', 'border-gold');
          }
        });
      });
    });
  </script>

