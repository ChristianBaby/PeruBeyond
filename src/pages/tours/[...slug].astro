---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { ui } from '../../i18n/ui';

// Otros tipos de Esperiencias
import ToursPeru from '../../components/ToursPeru.astro';

export async function getStaticPaths() {
  const tourEntries = await getCollection('tours');
  const paths = [];
  for (const entry of tourEntries) {
    const parts = entry.id.split('/');
    const lang = parts[0];
    const slug = parts.slice(1).join('/');
    if (lang === 'es') {
      // Ruta sin lang para español
      paths.push({
        params: { slug },
        props: { entry },
      });
    }
    // Ruta con lang para todos
    paths.push({
      params: { slug: `${lang}/${slug}` },
      props: { entry },
    });
  }
  return paths;
}

const slugParam = Astro.params.slug;
let lang = 'es';
let slug = slugParam;
if (slugParam.startsWith('en/') || slugParam.startsWith('pt/')) {
  const parts = slugParam.split('/');
  lang = parts[0];
  slug = parts.slice(1).join('/');
} else {
  lang = 'es';
  slug = slugParam;
}

const { entry } = Astro.props;
const t = ui[lang as keyof typeof ui] ?? ui.es;
const { title, image, price, duration, description, availability, frequency, difficulty, includes, excludes, itinerary, gallery, videoUrl, faq, wetravelUuid } = entry.data;
const { Content } = await render(entry);

const siteOrigin = (Astro.site ?? new URL('https://www.perubeyond.com')).origin;
const langAlternates = {
  es: `${siteOrigin}/tours/${slug}`,
  en: `${siteOrigin}/tours/en/${slug}`,
  pt: `${siteOrigin}/tours/pt/${slug}`,
};
---

<Layout
  title={title}
  description={description ?? 'Tour en Perú con Peru Beyond - Operador líder en Cusco.'}
  ogImage={image}
  langAlternates={langAlternates}
>
  <Header />

  

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="relative h-[80vh] w-full overflow-hidden">
    <img
      src={image}
      alt={title}
      class="absolute inset-0 w-full h-full object-cover scale-105 hero-img"
    />
    <!-- Overlay en dos capas: oscuridad base + degradado hacia abajo -->
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>

    <!-- Contenido del hero -->
    <div class="relative max-w-7xl mx-auto h-full flex flex-col justify-end pb-16 px-6">

      <!-- Breadcrumb -->
      <nav class="text-white/60 text-xs uppercase tracking-widest mb-5 flex items-center gap-2 hero-fade" style="animation-delay: 0.1s">
        <a href="/" class="hover:text-gold transition-colors">{t['tour.home']}</a>
        <span class="text-white/30">›</span>
        <a href="/tours" class="hover:text-gold transition-colors">{t['tour.tours']}</a>
        <span class="text-white/30">›</span>
        <span class="text-gold">{title}</span>
      </nav>

      <!-- Etiqueta flotante -->
      <div class="hero-fade mb-4" style="animation-delay: 0.2s">
        <span class="inline-flex items-center gap-2 bg-gold/20 border border-gold/40 backdrop-blur-sm text-gold text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full">
          <span class="w-1.5 h-1.5 bg-gold rounded-full animate-pulse"></span>
          Valle Sagrado de los Incas
        </span>
      </div>

      <!-- Título -->
      <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 leading-none tracking-tight hero-fade" style="animation-delay: 0.3s">
        {title}
      </h1>

      <!-- Precio + duración + separador -->
      <div class="flex flex-wrap items-center gap-4 hero-fade" style="animation-delay: 0.4s">
        <div class="flex items-baseline gap-1">
          <span class="text-white/50 text-sm">{t['tour.from']}</span>
          <span class="text-4xl font-black text-gold">${price}</span>
          <span class="text-white/50 text-sm">{t['tour.per_person']}</span>
        </div>
        <div class="w-px h-8 bg-white/20"></div>
        <div class="flex items-center gap-2 text-white/80 text-sm">
          <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          {duration}
        </div>
        {availability && (
          <div class="flex items-center gap-2 text-white/80 text-sm">
            <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            {availability}
          </div>
        )}
        <div class="w-px h-8 bg-white/20"></div>
        <!-- Botón de reserva directo desde el hero -->
        <a href="#contacto" class="ml-auto bg-orange-500 hover:bg-orange-400 text-white font-bold px-6 py-3 rounded-xl text-sm uppercase tracking-wider transition-all shadow-lg shadow-orange-500/30 hover:shadow-orange-400/40 hover:-translate-y-0.5">
          {t['tour.reserve_now']}
        </a>
      </div>

    </div>
  </section>
  
  <!-- ═══════════════════════════════════════════
       MENÚ SUPERIOR STICKY (CAMBIO DE POSICIÓN)
  ═══════════════════════════════════════════ -->
  <nav id="floating-menu" class="sticky top-0 z-50 w-full bg-navy/95 backdrop-blur border-b border-white/10 shadow-lg transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-center gap-4 md:gap-8 overflow-x-auto no-scrollbar">
      
      <a href="#incluye" class="menu-link group flex items-center gap-2 text-sm font-medium text-white/80 hover:text-white transition-colors relative py-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span>{t['tour.what_includes']}</span>
        <span class="absolute bottom-0 left-0 w-full h-0.5 bg-gold transform scale-x-0 group-[.active]:scale-x-100 transition-transform duration-300"></span>
      </a>

      <a href="#itinerario" class="menu-link group flex items-center gap-2 text-sm font-medium text-white/80 hover:text-white transition-colors relative py-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        <span>{t['tour.itinerary']}</span>
        <span class="absolute bottom-0 left-0 w-full h-0.5 bg-gold transform scale-x-0 group-[.active]:scale-x-100 transition-transform duration-300"></span>
      </a>

      <a href="#galeria" class="menu-link group flex items-center gap-2 text-sm font-medium text-white/80 hover:text-white transition-colors relative py-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span>{t['tour.gallery']}</span>
        <span class="absolute bottom-0 left-0 w-full h-0.5 bg-gold transform scale-x-0 group-[.active]:scale-x-100 transition-transform duration-300"></span>
      </a>

      <a href="#comentarios" class="menu-link group flex items-center gap-2 text-sm font-medium text-white/80 hover:text-white transition-colors relative py-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        <span>{t['tour.reviews']}</span>
        <span class="absolute bottom-0 left-0 w-full h-0.5 bg-gold transform scale-x-0 group-[.active]:scale-x-100 transition-transform duration-300"></span>
      </a>

      <a href="#contacto" class="hidden md:flex items-center gap-2 text-sm font-bold text-gold hover:text-white transition-colors ml-4 pl-4 border-l border-white/20">
        {t['tour.reserve']}
      </a>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════
       MAIN CONTENT + SIDEBAR
  ═══════════════════════════════════════════ -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-16 grid grid-cols-1 lg:grid-cols-3 gap-12">

    <!-- COLUMNA IZQUIERDA -->
    <div class="lg:col-span-2 space-y-16">

      <!-- ── SECCIÓN: DESCRIPCIÓN ── -->
      <section>
        <!-- Encabezado de sección (patrón reutilizable para todas las secciones) -->
        <div class="flex items-center gap-4 mb-8">
          <div class="w-1 h-10 bg-gold rounded-full"></div>
          <h2 class="text-3xl font-extrabold text-navy">{t['tour.description']}</h2>
        </div>

        <!-- Descripción corta destacada (viene del frontmatter) -->
        {description && (
          <p class="text-lg text-gray-600 leading-relaxed border-l-4 border-gold/30 pl-5 mb-8 italic">
            {description}
          </p>
        )}

        <!-- Cuerpo del Markdown (párrafos principales) -->
        <div class="prose prose-lg max-w-none text-gray-700
                    prose-p:leading-relaxed prose-p:mb-5
                    prose-strong:text-navy prose-strong:font-semibold">
          <Content />
        </div>

        <!-- Badges de info rápida -->
        <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-4">
          {availability && (
            <div class="bg-gray-50 border border-gray-100 rounded-2xl p-4 text-center hover:border-gold/40 transition-colors">
              <div class="text-2xl mb-1">📅</div>
              <div class="text-[10px] uppercase tracking-widest text-gray-400 font-semibold mb-0.5">{t['tour.availability']}</div>
              <div class="text-sm font-bold text-navy">{availability}</div>
            </div>
          )}
          {duration && (
            <div class="bg-gray-50 border border-gray-100 rounded-2xl p-4 text-center hover:border-gold/40 transition-colors">
              <div class="text-2xl mb-1">⏱</div>
              <div class="text-[10px] uppercase tracking-widest text-gray-400 font-semibold mb-0.5">{t['tour.duration']}</div>
              <div class="text-sm font-bold text-navy">{duration}</div>
            </div>
          )}
          {frequency && (
            <div class="bg-gray-50 border border-gray-100 rounded-2xl p-4 text-center hover:border-gold/40 transition-colors">
              <div class="text-2xl mb-1">🗓</div>
              <div class="text-[10px] uppercase tracking-widest text-gray-400 font-semibold mb-0.5">{t['tour.frequency']}</div>
              <div class="text-sm font-bold text-navy">{frequency}</div>
            </div>
          )}
          {difficulty && (
            <div class="bg-gray-50 border border-gray-100 rounded-2xl p-4 text-center hover:border-gold/40 transition-colors">
              <div class="text-2xl mb-1">🥾</div>
              <div class="text-[10px] uppercase tracking-widest text-gray-400 font-semibold mb-0.5">{t['tour.difficulty']}</div>
              <div class="text-sm font-bold text-navy">{difficulty}</div>
            </div>
          )}
        </div>
      </section>  

      <!-- ── SECCIÓN: INCLUYE / NO INCLUYE (MODIFICADO - DISEÑO MÁS LIMPIO) ── -->
      {(includes || excludes) && (
        <section id = "incluye" >
          <div class="flex items-center gap-4 mb-8">
            <div class="w-1 h-10 bg-gold rounded-full"></div>
            <h2 class="text-3xl font-extrabold text-navy">{t['tour.what_includes']}</h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

            <!-- Incluye -->
            {includes && (
              <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="bg-emerald-50 px-6 py-4 border-b border-emerald-100">
                  <h3 class="text-lg font-bold text-emerald-800 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    {t['tour.includes']}
                  </h3>
                </div>
                <ul class="p-6 space-y-4">
                  {includes.map((item) => (
                    <li class="flex items-start gap-3 text-sm text-gray-700">
                      <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center">
                        <svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                        </svg>
                      </span>
                      <span class="leading-relaxed">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- No incluye -->
            {excludes && (
              <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="bg-red-50 px-6 py-4 border-b border-red-100">
                  <h3 class="text-lg font-bold text-red-800 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    {t['tour.not_included']}
                  </h3>
                </div>
                <ul class="p-6 space-y-4">
                  {excludes.map((item) => (
                    <li class="flex items-start gap-3 text-sm text-gray-700">
                      <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-red-100 flex items-center justify-center">
                        <svg class="w-3 h-3 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                      </span>
                      <span class="leading-relaxed">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

          </div>
        </section>
      )}



      <!--ITINERARIO  -->
      <!-- ── SECCIÓN: ITINERARIO ── -->
      {itinerary && itinerary.length > 0 && (
        <section id = "itinerario" >
          <div class="flex items-center gap-4 mb-10">
            <div class="w-1 h-10 bg-gold rounded-full"></div>
            <h2 class="text-3xl font-extrabold text-navy">{t['tour.itinerary']}</h2>
          </div>
      
          <div class="relative">
            <div class="absolute left-[39px] top-0 bottom-0 w-px border-l-2 border-dashed border-gray-200 z-0"></div>
      
            <div class="space-y-8">
              {itinerary.map((item, index) => (
                <div class="relative flex gap-6">
      
                  <!-- Badge DIA -->
                  <div class="relative z-10 flex-shrink-0 flex flex-col items-center justify-center w-20 h-20 bg-orange-500 text-white rounded-2xl shadow-lg shadow-orange-200">
                    <span class="text-[10px] font-bold uppercase tracking-widest leading-none">{t['tour.day']}</span>
                    <span class="text-3xl font-black leading-none">
                      {String(item.day).padStart(2, '0')}
                    </span>
                  </div>
      
                  <!-- Contenido del día -->
                  <div class="flex-1 pb-10">
                    <h3 class="text-xl font-bold text-navy mb-2 mt-3">{item.title}</h3>
      
                    {item.description && (
                      <p class="text-gray-500 text-sm mb-4 leading-relaxed">{item.description}</p>
                    )}
      
                    {item.activities && (
                      <ul class="space-y-2 mb-6">
                        {item.activities.map((act) => (
                          <li class="flex items-start gap-3 text-sm text-gray-700">
                            <span class="mt-1.5 flex-shrink-0 w-2 h-2 rounded-full bg-orange-400"></span>
                            {act}
                          </li>
                        ))}
                      </ul>
                    )}
      
                          <!-- Carrusel de imágenes del día -->
                    {item.images && item.images.length > 0 && (
                      <div class="relative group mt-2" id={`carousel-${index}`}>
                        
                        <!-- Wrapper con overflow hidden — este NO se mueve -->
                        <div class="overflow-hidden rounded-2xl">
                          <!-- Track — este SÍ se mueve -->
                          <div
                            class="carousel-track flex gap-3"
                            data-carousel={`carousel-${index}`}
                            style="transition: transform 0.4s ease;"
                          >
                            {item.images.map((img, i) => (
                              <img
                                src={img}
                                alt={`${item.title} - imagen ${i + 1}`}
                                class="carousel-slide flex-shrink-0 w-[calc(33.333%-8px)] h-52 object-cover rounded-xl"
                              />
                            ))}
                          </div>
                        </div>

                        <!-- Botón anterior -->
                        <button
                          class="carousel-prev absolute left-2 top-[calc(50%-16px)] -translate-y-1/2 z-10
                                w-9 h-9 bg-white/90 hover:bg-white rounded-full shadow-lg
                                flex items-center justify-center opacity-0 group-hover:opacity-100
                                transition-opacity"
                          data-target={`carousel-${index}`}
                        >
                          <svg class="w-4 h-4 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/>
                          </svg>
                        </button>

                        <!-- Botón siguiente -->
                        <button
                          class="carousel-next absolute right-2 top-[calc(50%-16px)] -translate-y-1/2 z-10
                                w-9 h-9 bg-white/90 hover:bg-white rounded-full shadow-lg
                                flex items-center justify-center opacity-0 group-hover:opacity-100
                                transition-opacity"
                          data-target={`carousel-${index}`}
                        >
                          <svg class="w-4 h-4 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                          </svg>
                        </button>

                        <!-- Dots -->
                        {item.images.length > 3 && (
                          <div class="flex justify-center gap-1.5 mt-3" data-dots={`carousel-${index}`}>
                            {item.images.map((_, i) => (
                              <button
                                class={`dot w-1.5 h-1.5 rounded-full transition-all duration-300 ${i === 0 ? 'bg-orange-500 !w-4' : 'bg-gray-300'}`}
                                data-carousel={`carousel-${index}`}
                                data-index={String(i)}
                              />
                            ))}
                          </div>
                        )}

                      </div>
                    )}
                  </div>
      
                </div>
              ))}
            </div>
          </div>
        </section>
      )}


      <!-- ── LIGHTBOX ── -->
      {gallery && gallery.length > 0 && (
        <div id="lightbox" class="fixed inset-0 z-50 bg-black/95 hidden items-center justify-center">
          <button
            id="lightbox-close"
            class="absolute top-5 right-5 text-white/70 hover:text-white text-4xl font-light leading-none z-10"
          >
            ×
          </button>

          <button id="lightbox-prev"
            class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center text-white transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
          </button>

          <img id="lightbox-img" src="" alt=""
            class="max-h-[85vh] max-w-[85vw] object-contain rounded-xl shadow-2xl" />

          <button id="lightbox-next"
            class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-white/10 hover:bg-white/20 rounded-full flex items-center justify-center text-white transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </button>

          <div id="lightbox-counter" class="absolute bottom-5 left-1/2 -translate-x-1/2 text-white/60 text-sm"></div>
        </div>
      )}

      <!-- ── SECCIÓN: PREGUNTAS FRECUENTES ── -->
      {faq && faq.length > 0 && (
        <section>
          <div class="flex items-center gap-4 mb-8">
            <div class="w-1 h-10 bg-gold rounded-full"></div>
            <h2 class="text-3xl font-extrabold text-navy">{t['tour.faq']}</h2>
          </div>

          <div class="divide-y divide-gray-100" id="faq-list">
            {faq.map((item, index) => (
              <div class="faq-item py-5" data-index={String(index)}>
                <button
                  class="faq-trigger w-full flex items-center justify-between gap-4 text-left group"
                  data-index={String(index)}
                >
                  <span class="text-base font-bold text-navy group-hover:text-gold transition-colors">
                    {String(index + 1).padStart(2, '0')}. {item.question}
                  </span>
                  <span class="faq-icon flex-shrink-0 w-7 h-7 rounded-full border border-gray-200 flex items-center justify-center text-gray-400 group-hover:border-gold group-hover:text-gold transition-all text-lg font-light">
                    +
                  </span>
                </button>

                <div class="faq-answer overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
                  <p class="text-gray-500 text-sm leading-relaxed pt-4 pb-2 pl-8">
                    {item.answer}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}



      <!-- AQUÍ irán las demás secciones: Incluye, Itinerario, Galería, FAQ, etc. -->
       

    
    
    </div>

    <!-- SIDEBAR (formulario de contacto) -->
    <aside id="contacto" class="relative">
      <div class="sticky top-24 bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-100">
        <!-- Botón WeTravel -->
        {wetravelUuid && (
          <div class="px-6 pt-6 pb-4 border-b border-gray-100">
            <p class="text-xs text-gray-400 uppercase tracking-widest mb-3 text-center">
              {t['tour.safe_booking']}
            </p>
            <div style="text-align: center;">
              <a
                class="wtrvl-checkout_button"
                id="wetravel_button_widget"
                data-env="https://www.wetravel.com"
